{
  "name": "electrobun-svelte-tailwind-vite",
  "version": "1.0.0",
  "description": "Electrobun app with Svelte, Tailwind CSS, and Vite HMR",
  "type": "module",
  "scripts": {
    "dev": "bun run build && electrobun dev",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
    "dev:web": "vite dev",
    "hmr": "vite --port 5173",
    "build:native-effects": "bash ./scripts/build-macos-effects.sh",
    "build": "bun run build:native-effects && vite build && electrobun build",
    "build:prod": "bun run build:native-effects && vite build && electrobun build --channel prod",
    "start": "bun run dev"
  },
  "dependencies": {
    "@bmlt-enabled/svelte-spa-router": "^5.0.7",
    "electrobun": "1.16.0",
    "mode-watcher": "^1.1.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/svelte": "^1.1.2",
    "@internationalized/date": "^3.12.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "svelte": "^5.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^5.0.0"
  }
}
